generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DevRequestImage {
  id        String   @id @default(cuid())
  data      String   // base64 image data
  mimeType  String
  createdAt DateTime @default(now())
}

model AppUpdate {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String   @default("improve") // feature|fix|improve
  page        String?  // 표시 대상 페이지 경로
  createdAt   DateTime @default(now())
}
